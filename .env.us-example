# SparkStage US Version - Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# ============================================
# Supabase Configuration
# ============================================
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...

# ============================================
# App Configuration
# ============================================
VITE_APP_URL=https://your-us-app.vercel.app
VITE_CURRENCY=USD
VITE_LOCALE=en-US

# ============================================
# Stripe Configuration (US Payment Gateway)
# ============================================
# Get from: https://dashboard.stripe.com/apikeys
# Use TEST keys for development, LIVE keys for production

# Test Mode (for development)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_51xxxxx

# Production Mode (uncomment when ready)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_51xxxxx

# ============================================
# Feature Flags
# ============================================
VITE_ENABLE_STRIPE=true
VITE_ENABLE_PAYPAL=false
VITE_ENABLE_SQUARE=false

# ============================================
# Optional: Analytics & Monitoring
# ============================================
# VITE_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
# VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# ============================================
# Backend Secrets (Set in Supabase Dashboard)
# ============================================
# DO NOT PUT THESE IN FRONTEND .env FILE!
# Use: supabase secrets set KEY=VALUE

# Stripe Secrets
# STRIPE_SECRET_KEY=sk_test_xxxxx (or sk_live_xxxxx for production)
# STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Shipping Secrets
# EASYPOST_API_KEY=EZAK...

# App Secrets
# PUBLIC_APP_URL=https://your-us-app.vercel.app
# APP_ALLOWED_ORIGINS=https://your-us-app.vercel.app

# ============================================
# Notes
# ============================================
# 1. Never commit this file with real values to git
# 2. Keep .env.local in .gitignore
# 3. Update values in Vercel/Netlify dashboard for production
# 4. Use Supabase secrets for backend environment variables
