{
  "name": "sparkstage-us",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "imagekit:migrate": "node scripts/imagekit-migrate-product-images.mjs --env-file .env.imagekit-migration --batch-size 25",
    "imagekit:migrate:dry": "node scripts/imagekit-migrate-product-images.mjs --env-file .env.imagekit-migration --dry-run --batch-size 25 --limit 25",
    "imagekit:migration:status": "node scripts/imagekit-migration-status.mjs --env-file .env.imagekit-migration",
    "r2:migrate": "node scripts/migrate-imagekit-to-r2.mjs --env-file .env.r2-migration --batch-size 50",
    "r2:migrate:dry": "node scripts/migrate-imagekit-to-r2.mjs --env-file .env.r2-migration --dry-run --batch-size 25 --limit 25",
    "r2:migrate:status": "node scripts/r2-migration-status.mjs --env-file .env.r2-migration",
    "r2:verify": "node scripts/verify-r2-urls.mjs",
    "r2:cutover:dry": "node scripts/r2-cutover-database.mjs --env-file .env.r2-migration --dry-run",
    "r2:cutover:confirm": "node scripts/r2-cutover-database.mjs --env-file .env.r2-migration --confirm",
    "test": "vitest run",
    "test:backend": "vitest run --config vitest.backend.config.ts",
    "preview": "vite preview",
    "supabase:db:list": "supabase migration list",
    "supabase:db:push": "supabase db push",
    "supabase:db:push:whatsapp": "supabase db push supabase/migrations/20260513000000_add_whatsapp_messages_table.sql",
    "supabase:db:reset": "supabase db reset",
    "supabase:types:check": "node scripts/check-supabase-types.mjs",
    "supabase:types:check:linked": "node scripts/check-supabase-types-linked.mjs",
    "supabase:release:check": "node scripts/verify-supabase-release.mjs",
    "supabase:functions:deploy:complete-product-pickup": "supabase functions deploy complete-product-pickup",
    "supabase:functions:deploy:create-doku-product-checkout": "supabase functions deploy create-doku-product-checkout",
    "supabase:functions:deploy:create-doku-ticket-checkout": "supabase functions deploy create-doku-ticket-checkout",
    "supabase:functions:deploy:doku-webhook": "supabase functions deploy doku-webhook",
    "supabase:functions:deploy:send-whatsapp-invoice": "supabase functions deploy send-whatsapp-invoice",
    "supabase:functions:deploy:sync-doku-ticket-status": "supabase functions deploy sync-doku-ticket-status",
    "supabase:functions:deploy:sync-doku-product-status": "supabase functions deploy sync-doku-product-status",
    "supabase:functions:deploy:reconcile-doku-payments": "supabase functions deploy reconcile-doku-payments",
    "supabase:functions:deploy:all": "supabase functions deploy && npm run supabase:functions:deploy:doku-webhook && npm run supabase:functions:deploy:send-whatsapp-invoice",
    "supabase:functions:serve": "supabase functions serve",
    "supabase:functions:logs": "supabase functions logs",
    "supabase:secrets:set": "supabase secrets set",
    "supabase:secrets:list": "supabase secrets list",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "data:identify-dummy": "node --loader tsx scripts/identify-dummy-data.ts",
    "data:validate-production": "node --loader tsx scripts/validate-production-data.ts",
    "data:cleanup-dummy": "node --loader tsx scripts/cleanup-dummy-data.ts",
    "data:cleanup-dummy:confirm": "node --loader tsx scripts/cleanup-dummy-data.ts --confirm",
    "data:sync-dummy-to-production": "node --loader tsx scripts/sync-dummy-to-production.ts",
    "data:sync-dummy-to-production:confirm": "node --loader tsx scripts/sync-dummy-to-production.ts --sync"
  },
