# Cloudflare R2 Configuration
# Get these from: https://dash.cloudflare.com → R2 → Manage R2 API Tokens

R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=sparkstage-public-assets
R2_BASE_PATH=products

# Public URL for accessing R2 files
# Option 1: Custom domain (recommended for production)
R2_PUBLIC_BASE_URL=https://media.sparkstage55.com

# Option 2: R2.dev domain (for testing)
# R2_PUBLIC_BASE_URL=https://pub-xxxxxxxxxxxxx.r2.dev

# Supabase (optional - will auto-detect from CLI if not provided)
# SUPABASE_URL=https://hogzjapnkvsihvvbgcdb.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
