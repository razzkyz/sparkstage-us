{
  "name": "sparkstage-us",
  "description": "US market version - Dependencies to ADD to existing SparkStage setup",
  "newDependencies": {
    "frontend": {
      "@stripe/stripe-js": "^2.4.0",
      "@stripe/react-stripe-js": "^2.4.0",
      "stripe": "^14.14.0"
    },
    "backend": {
      "stripe": "https://esm.sh/stripe@14.14.0",
      "@easypost/api": "https://esm.sh/@easypost/api@7.0.0"
    }
  },
  "dependenciesToRemove": {
    "frontend": [
      "@doku/jokul-checkout-js (DOKU SDK - not needed for US)"
    ],
    "backend": []
  },
  "keepFromOriginal": {
    "frontend": [
      "@supabase/supabase-js",
      "@tanstack/react-query",
      "@tanstack/react-query-devtools",
      "react",
      "react-dom",
      "react-router-dom",
      "i18next",
      "react-i18next",
      "i18next-browser-languagedetector",
      "lucide-react",
      "framer-motion",
      "clsx",
      "tailwind-merge",
      "qrcode",
      "react-qr-code",
      "html5-qrcode",
      "@aws-sdk/client-s3",
      "@aws-sdk/s3-request-presigner",
      "canvas-confetti",
      "xlsx"
    ],
    "devDependencies": [
      "vite",
      "@vitejs/plugin-react",
      "typescript",
      "tailwindcss",
      "@tailwindcss/vite",
      "autoprefixer",
      "postcss",
      "eslint",
      "@testing-library/react",
      "@testing-library/jest-dom",
      "vitest",
      "jsdom"
    ]
  },
  "environmentVariables": {
    "frontend": {
      "VITE_SUPABASE_URL": "Your Supabase project URL",
      "VITE_SUPABASE_ANON_KEY": "Your Supabase anon key",
      "VITE_APP_URL": "https://your-us-app.com",
      "VITE_STRIPE_PUBLISHABLE_KEY": "pk_test_... or pk_live_...",
      "VITE_CURRENCY": "USD",
      "VITE_LOCALE": "en-US"
    },
    "backend_supabase_secrets": {
      "STRIPE_SECRET_KEY": "sk_test_... or sk_live_...",
      "STRIPE_WEBHOOK_SECRET": "whsec_...",
      "EASYPOST_API_KEY": "EZAK...",
      "USPS_USER_ID": "(optional if using USPS direct)",
      "FEDEX_API_KEY": "(optional if using FedEx direct)",
      "UPS_API_KEY": "(optional if using UPS direct)",
      "PUBLIC_APP_URL": "https://your-us-app.com",
      "APP_ALLOWED_ORIGINS": "https://your-us-app.com,https://admin.your-us-app.com"
    }
  },
  "installCommands": {
    "frontend": [
      "npm install @stripe/stripe-js@^2.4.0",
      "npm install @stripe/react-stripe-js@^2.4.0"
    ],
    "backend": [
      "# No npm install needed - Supabase Edge Functions use ESM imports",
      "# Example: import Stripe from 'https://esm.sh/stripe@14.14.0'"
    ]
  },
  "migrationSteps": [
    {
      "step": 1,
      "title": "Setup Stripe Account",
      "actions": [
        "Create Stripe account at https://stripe.com",
        "Get test API keys from Dashboard > Developers > API keys",
        "Enable webhook endpoint in Dashboard > Developers > Webhooks",
        "Add webhook URL: https://your-project.supabase.co/functions/v1/stripe-webhook",
        "Select events: payment_intent.succeeded, payment_intent.payment_failed, charge.refunded"
      ]
    },
    {
      "step": 2,
      "title": "Install Frontend Dependencies",
      "actions": [
        "cd frontend",
        "npm install @stripe/stripe-js @stripe/react-stripe-js",
        "npm uninstall @doku/jokul-checkout-js (if exists)"
      ]
    },
    {
      "step": 3,
      "title": "Update Environment Variables",
      "actions": [
        "Copy .env.example to .env.local",
        "Update VITE_STRIPE_PUBLISHABLE_KEY",
        "Update VITE_CURRENCY=USD",
        "Update VITE_LOCALE=en-US"
      ]
    },
    {
      "step": 4,
      "title": "Configure Supabase Secrets",
      "actions": [
        "supabase secrets set STRIPE_SECRET_KEY=sk_test_...",
        "supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_...",
        "supabase secrets set EASYPOST_API_KEY=EZAK... (if using shipping)"
      ]
    },
    {
      "step": 5,
      "title": "Database Migration",
      "actions": [
        "Create new migration: supabase migration new stripe_payment_integration",
        "Add columns: stripe_payment_intent_id, stripe_customer_id",
        "Update RLS policies",
        "Run: npm run supabase:db:push"
      ]
    },
    {
      "step": 6,
      "title": "Create Edge Functions",
      "actions": [
        "supabase functions new create-stripe-ticket-checkout",
        "supabase functions new stripe-webhook",
        "supabase functions new calculate-shipping-cost",
        "Deploy: supabase functions deploy"
      ]
    },
    {
      "step": 7,
      "title": "Update Frontend Components",
      "actions": [
        "Replace DOKU Jokul SDK with Stripe Elements in PaymentPage.tsx",
        "Update ProductCheckoutPage.tsx with Stripe integration",
        "Add shipping address form",
        "Update success pages"
      ]
    },
    {
      "step": 8,
      "title": "Testing",
      "actions": [
        "Use Stripe test cards (4242 4242 4242 4242)",
        "Test webhook with: stripe listen --forward-to localhost:54321/functions/v1/stripe-webhook",
        "Verify payment flow end-to-end",
        "Test refund flow"
      ]
    },
    {
      "step": 9,
      "title": "Deploy to Production",
      "actions": [
        "Switch to Stripe live API keys",
        "Update webhook URL to production",
        "Deploy frontend: vercel deploy --prod",
        "Deploy functions: supabase functions deploy",
        "Monitor first 24 hours closely"
      ]
    }
  ],
  "costComparison": {
    "indonesia_doku": {
      "transaction_fee": "2.5% + Rp 2,000",
      "monthly_fee": "Varies by merchant tier",
      "currency": "IDR"
    },
    "us_stripe": {
      "card_transaction": "2.9% + $0.30",
      "ach_transaction": "0.8% (capped at $5)",
      "international_card": "+1.5% additional",
      "monthly_fee": "$0 (pay-as-you-go)",
      "currency": "USD"
    }
  },
  "alternativePaymentGateways": {
    "paypal": {
      "pros": ["Widely recognized", "PayPal + Venmo support", "Good for B2C"],
      "cons": ["Higher fees (3.49% + $0.49)", "Customer disputes favor buyers"],
      "transaction_fee": "3.49% + $0.49",
      "npm_package": "@paypal/checkout-server-sdk"
    },
    "square": {
      "pros": ["Unified POS", "Good for in-person + online", "No monthly fee"],
      "cons": ["Limited international support", "Fewer features than Stripe"],
      "transaction_fee": "2.9% + $0.30 (online), 2.6% + $0.10 (in-person)",
      "npm_package": "square"
    },
    "braintree": {
      "pros": ["PayPal owned", "Supports Venmo", "Good fraud protection"],
      "cons": ["Complex setup", "Slower support"],
      "transaction_fee": "2.9% + $0.30",
      "npm_package": "braintree"
    }
  },
  "shippingProviders": {
    "easypost": {
      "description": "Multi-carrier shipping API (USPS, FedEx, UPS, DHL)",
      "pricing": "$0.05 per label + carrier rates",
      "npm_package": "@easypost/api",
      "pros": ["Single API for all carriers", "Commercial pricing", "Address validation"],
      "website": "https://www.easypost.com"
    },
    "shipengine": {
      "description": "Shipping API aggregator",
      "pricing": "$0.05 per label",
      "npm_package": "shipengine",
      "pros": ["Multi-carrier support", "Good documentation"],
      "website": "https://www.shipengine.com"
    },
    "usps_direct": {
      "description": "USPS Web Tools API",
      "pricing": "Free API, pay carrier rates",
      "npm_package": "usps-webtools",
      "pros": ["Free", "Official USPS API"],
      "cons": ["USPS only", "Complex XML API"],
      "website": "https://www.usps.com/business/web-tools-apis/"
    },
    "fedex_direct": {
      "description": "FedEx Web Services",
      "pricing": "Free API, pay carrier rates",
      "npm_package": "shipping-fedex",
      "pros": ["Direct integration", "Real-time rates"],
      "cons": ["FedEx only", "Complex setup"],
      "website": "https://developer.fedex.com"
    }
  },
  "recommendedStack": {
    "payment": "Stripe (best all-around for US market)",
    "shipping": "EasyPost (easiest multi-carrier integration)",
    "database": "Supabase Postgres (keep same as original)",
    "storage": "Cloudflare R2 (keep same as original)",
    "frontend": "Vite + React + TypeScript (keep same)",
    "styling": "Tailwind CSS (keep same)"
  }
}
